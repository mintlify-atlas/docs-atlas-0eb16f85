  "keyFeatures": [
    "Plugin-driven architecture built on ProseMirror and remark",
    "WYSIWYG markdown editing with live preview",
    "Crepe — a ready-to-use editor with sensible defaults",
    "React and Vue integrations via official packages",
    "GFM (GitHub Flavored Markdown) and CommonMark support",
    "Real-time collaborative editing via Yjs",
    "Slash commands, block editing, and rich toolbar",
    "Code blocks with syntax highlighting via CodeMirror",
    "LaTeX / KaTeX math formula support",
    "Streaming AI input with progressive rendering",
    "Customizable themes and components"
  ],
  "publicApiSurface": [
    "Editor.make() — creates a new editor instance",
    "Editor#use(plugins) — registers plugins",
    "Editor#config(fn) — configures the editor context",
    "Editor#create() — mounts and initializes the editor",
    "Editor#destroy() — tears down the editor",
    "Editor#action(fn) — runs an action against the editor ctx",
    "Crepe — high-level editor class wrapping core Editor",
    "CrepeFeature — enum of all optional Crepe features",
    "listenerCtx / listener — event subscription plugin",
    "commonmarkPreset — preset for CommonMark support",
    "gfmPreset — preset for GitHub Flavored Markdown",
    "@milkdown/react: useEditor, MilkdownProvider, Milkdown",
    "@milkdown/vue: useEditor, MilkdownEditor",
    "createSlice / createTimer — ctx primitives for plugin authors",
    "MilkdownPlugin — base type for all plugins"
  ]
